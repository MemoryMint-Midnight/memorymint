# Copy to midnight/.env and fill in values — never commit .env

# Port the sidecar listens on
PORT=4000

# Midnight network: "preprod" (default) or "mainnet"
MIDNIGHT_NETWORK_ID=preprod

# Midnight network endpoints (preprod defaults are fine for development)
MIDNIGHT_INDEXER=https://indexer.preprod.midnight.network/api/v4/graphql
MIDNIGHT_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
MIDNIGHT_NODE=https://rpc.preprod.midnight.network
PROOF_SERVER_URL=http://127.0.0.1:6300

# 24-word BIP-39 seed phrase for the server-side Midnight wallet.
# This wallet pays DUST fees for contract deployment.
# Generate in the Lace wallet (use a dedicated testnet wallet, not your main one).
MIDNIGHT_WALLET_SEED=

# Shared secret between this service and the Next.js app / WordPress plugin.
# Generate with: openssl rand -hex 32
# Set the SAME value in the Next.js MIDNIGHT_API_SECRET env var.
MIDNIGHT_API_SECRET=

# URL of the Next.js app (for CORS — single origin)
NEXT_PUBLIC_URL=http://localhost:3000

# Optional: comma-separated allowlist of CORS origins. When set, overrides NEXT_PUBLIC_URL.
# Use this on production if the app is served from multiple domains.
# CORS_ALLOWED_ORIGINS=https://memorymint.fun,https://www.memorymint.fun

# Optional: pino log level (trace, debug, info, warn, error). Default: info
# LOG_LEVEL=info

# Path to the encrypted private state file (survives sidecar restarts).
# Defaults to ./midnight-private-state.json — set an absolute path on the VPS.
# Add this file to .gitignore — it contains encrypted contract state.
PRIVATE_STATE_PATH=/data/memorymint/private-state.json
