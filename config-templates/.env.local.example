# Memory Mint â€” LOCAL DEVELOPMENT environment variables
# Copy this file to frontend/.env.local and fill in your values.
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Coming Soon mode (set true to show coming-soon page to all visitors)
COMING_SOON=false
COMING_SOON_BYPASS=mmpreview

# Your local WordPress URL (no trailing slash)
# If using Local by Flywheel the site URL is shown in the app.
NEXT_PUBLIC_WORDPRESS_API_URL=http://memorymint.local/wp-json/wp/v2

# Cardano network â€” use preprod for local testing
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# Anvil API key for PREPROD (get free at https://ada-anvil.app)
# Preprod keys start with: testnet_
NEXT_PUBLIC_ANVIL_API_KEY=testnet_XXXXXXXXXXXXXXXXXXXX
