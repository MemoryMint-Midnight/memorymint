# ─────────────────────────────────────────────────────────────────────────────
# Memory Mint — LOCAL DEVELOPMENT environment variables
# Copy this file to frontend/.env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Coming Soon mode (set true to show coming-soon page to all visitors)
COMING_SOON=false
COMING_SOON_BYPASS=mmpreview

# Your local WordPress URL (no trailing slash, include /wp/v2)
# If using Local by Flywheel the site URL is shown in the app.
NEXT_PUBLIC_WORDPRESS_API_URL=http://memorymint.local/wp-json/wp/v2

# Cardano network — use preprod for local testing
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# NOTE: The Anvil API key lives in the WordPress plugin settings
# (WP Admin → Memory Mint → Settings), NOT in the frontend environment.
# Never add NEXT_PUBLIC_ANVIL_API_KEY here — it would be exposed in the browser bundle.
