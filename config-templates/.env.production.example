# Memory Mint â€” PRODUCTION environment variables
# Copy this file to frontend/.env.production and fill in your values.
# NEVER commit this file to version control.
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Coming Soon mode
COMING_SOON=false
COMING_SOON_BYPASS=mmpreview

# Your production WordPress URL (must be HTTPS in production)
NEXT_PUBLIC_WORDPRESS_API_URL=https://your-wordpress-domain.com/wp-json/wp/v2

# Cardano network â€” mainnet for live
NEXT_PUBLIC_CARDANO_NETWORK=mainnet

# Anvil API key for MAINNET (get at https://ada-anvil.app)
# Mainnet keys start with: mainnet_
NEXT_PUBLIC_ANVIL_API_KEY=mainnet_XXXXXXXXXXXXXXXXXXXX
