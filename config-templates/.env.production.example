# ─────────────────────────────────────────────────────────────────────────────
# Memory Mint — PRODUCTION environment variables
# Copy this file to frontend/.env.production and fill in your values.
# NEVER commit this file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Coming Soon mode
COMING_SOON=false
COMING_SOON_BYPASS=mmpreview

# Your production WordPress URL (must be HTTPS in production, include /wp/v2)
NEXT_PUBLIC_WORDPRESS_API_URL=https://your-wordpress-domain.com/wp-json/wp/v2

# Cardano network — mainnet for live
NEXT_PUBLIC_CARDANO_NETWORK=mainnet

# NOTE: The Anvil API key lives in the WordPress plugin settings
# (WP Admin → Memory Mint → Settings), NOT in the frontend environment.
# Never add NEXT_PUBLIC_ANVIL_API_KEY here — it would be exposed in the browser bundle.
