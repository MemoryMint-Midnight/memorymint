# ─────────────────────────────────────────────────────────────
# Memory Mint — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local or .env.production to version control.
# ─────────────────────────────────────────────────────────────

# Coming Soon mode
# Set to true to show the coming-soon page to all visitors.
# Access the real site with: /?preview=<COMING_SOON_BYPASS>
COMING_SOON=false
COMING_SOON_BYPASS=mmpreview

# WordPress REST API base URL (include /wp/v2 at the end)
# Local dev:  http://memorymint.local/wp-json/wp/v2
# Production: https://your-wp-domain.com/wp-json/wp/v2
NEXT_PUBLIC_WORDPRESS_API_URL=http://memorymint.local/wp-json/wp/v2

# Cardano network: "preprod" (testnet) or "mainnet"
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# Anvil API key for the frontend (used by cardano.ts for tx building/submission)
# Get your key at https://ada-anvil.app
# Preprod key prefix: testnet_
# Mainnet key prefix: mainnet_
NEXT_PUBLIC_ANVIL_API_KEY=
